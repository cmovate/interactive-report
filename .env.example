# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/interactive_report

# Unipile DSN (e.g. https://api25.unipile.com:15554)
UNIPILE_DSN=https://api25.unipile.com:15554

# Unipile API key
UNIPILE_API_KEY=your_unipile_api_key_here

# Default Unipile account ID (optional)
UNIPILE_ACCOUNT_ID=

# Server port
PORT=3000
